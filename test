import time
import pandas as pd

from qdrant_client.models import Filter, FieldCondition, MatchValue

from application.vectordatabase.utils.util_functions import init_vector_database


def build_qdrant_filter(fonds: str, kennisbank: str):
    return Filter(
        must=[
            FieldCondition(
                key="metadata.kennisbank",
                match=MatchValue(value=str(kennisbank).upper()),
            ),
            FieldCondition(
                key="metadata.category",
                match=MatchValue(value=str(fonds).upper()),
            ),
        ]
    )


def simple_keyword_score(expected_answer: str, retrieved_context: str) -> float:
    expected_words = set(
        word.lower().strip(".,;:!?()[]{}\"'")
        for word in str(expected_answer).split()
        if len(word.strip()) > 3
    )

    if not expected_words:
        return 0.0

    context_lower = str(retrieved_context).lower()
    hits = [word for word in expected_words if word in context_lower]

    return round(len(hits) / len(expected_words), 3)


def run_retrieval_evaluation(questions: pd.DataFrame, logger):
    logger.info("Initializing vectordatabase")
    vector_db = init_vector_database()
    logger.info("Finished initializing vectordatabase")

    results = []

    for _, row in questions.iterrows():
        question_id = row["id"]
        question = row["question"]
        expected_answer = row["expected_answer"]
        fonds = row["fonds"]
        kennisbank = row["kennisbank"]
        k = int(row["k"])

        logger.info(f"Running evaluation for question {question_id}")

        start_time = time.time()

        try:
            qdrant_filter = build_qdrant_filter(
                fonds=fonds,
                kennisbank=kennisbank,
            )

            docs = vector_db.similarity_search(
                question,
                k=k,
                filter=qdrant_filter,
            )

            latency_seconds = round(time.time() - start_time, 3)

            retrieved_context = "\n\n".join(doc.page_content for doc in docs)
            retrieved_metadata = [doc.metadata for doc in docs]

            keyword_score = simple_keyword_score(
                expected_answer=expected_answer,
                retrieved_context=retrieved_context,
            )

            results.append(
                {
                    "id": question_id,
                    "topic": row.get("topic", ""),
                    "question": question,
                    "expected_answer": expected_answer,
                    "expected_source": row.get("expected_source", ""),
                    "fonds": fonds,
                    "kennisbank": kennisbank,
                    "k": k,
                    "num_docs_found": len(docs),
                    "keyword_score": keyword_score,
                    "latency_seconds": latency_seconds,
                    "retrieved_context": retrieved_context[:5000],
                    "retrieved_metadata": str(retrieved_metadata),
                    "error": "",
                }
            )

            logger.info(f"Question {question_id}: found {len(docs)} docs, keyword_score={keyword_score}")

        except Exception as e:
            logger.error(f"Question {question_id} failed: {e}", exc_info=True)

            results.append(
                {
                    "id": question_id,
                    "topic": row.get("topic", ""),
                    "question": question,
                    "expected_answer": expected_answer,
                    "expected_source": row.get("expected_source", ""),
                    "fonds": fonds,
                    "kennisbank": kennisbank,
                    "k": k,
                    "num_docs_found": 0,
                    "keyword_score": 0.0,
                    "latency_seconds": None,
                    "retrieved_context": "",
                    "retrieved_metadata": "",
                    "error": str(e),
                }
            )

    return pd.DataFrame(results)
import os
import sys

sys.path.append(os.path.join(os.path.dirname(__file__), "application", "vectordatabase", "src"))

from logger_factory import get_logger
from application.vectordatabase.utils.util_functions import load_config
from evaluation.data_loader import load_test_questions_from_excel
from evaluation.retrieval_evaluation import run_retrieval_evaluation


logger = get_logger()

config = load_config(os.environ["CONFIG"])
logger.info("Finished initializing config")


INPUT_FILE = "experiments/Testvragen Chat APG KCC.xlsx"
SHEET_NAME = "Testvragen PWRI"

QUESTIONS_OUTPUT_FILE = "output_files/evaluation_questions.csv"
RESULTS_OUTPUT_FILE = "output_files/evaluation_results.csv"


def main():
    logger.info("Loading evaluation questions")

    questions = load_test_questions_from_excel(
        input_path=INPUT_FILE,
        sheet_name=SHEET_NAME,
        default_fonds="PWRI",
        default_kennisbank="KCC",
        default_k=5,
    )

    logger.info(f"Loaded {len(questions)} evaluation questions")

    questions.to_csv(QUESTIONS_OUTPUT_FILE, index=False)
    logger.info(f"Saved normalized questions to {QUESTIONS_OUTPUT_FILE}")

    logger.info("Starting retrieval evaluation")
    results = run_retrieval_evaluation(
        questions=questions,
        logger=logger,
    )

    results.to_csv(RESULTS_OUTPUT_FILE, index=False)

    logger.info(f"Saved evaluation results to {RESULTS_OUTPUT_FILE}")
    logger.info(f"Average keyword score: {round(results['keyword_score'].mean(), 3)}")
    logger.info(f"Average docs found: {round(results['num_docs_found'].mean(), 2)}")

    print("Done")
    print(f"Results saved to: {RESULTS_OUTPUT_FILE}")
    print("Average keyword score:", round(results["keyword_score"].mean(), 3))
    print("Average docs found:", round(results["num_docs_found"].mean(), 2))


if __name__ == "__main__":
    main()


