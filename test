import os
import re
import json
import time
import asyncio
import pandas as pd
from pprint import pprint

from langchain.messages import HumanMessage, AIMessage

from application.models.chat_model import get_chat_model
from application.vectordatabase.utils.util_functions import load_config
from backend.graph import build_rag_agent


# ========================================================
# INSTELLINGEN
# ========================================================

OUTPUT_DIR = "output_files"

INPUT_FILE = f"{OUTPUT_DIR}/evaluation_questions.csv"
OUTPUT_FILE = f"{OUTPUT_DIR}/rag_evaluation_results.csv"

USE_COMBINED_MODEL = True
ENABLE_PHOENIX = True

# Belangrijk:
# True = exact zoals test_agent.py: history blijft bestaan
# False = elke vraag wordt volledig los getest
USE_CONVERSATION_HISTORY = True

# Zet op True om te zien welke config/result gebruikt wordt
DEBUG = True

# Zet op True als je alleen de eerste paar vragen wil testen
LIMIT_QUESTIONS = None
# voorbeeld:
# LIMIT_QUESTIONS = 3


# ========================================================
# HELPERS
# ========================================================

def ensure_output_dir():
    if not os.path.exists(OUTPUT_DIR):
        os.makedirs(OUTPUT_DIR)


def normalize_text(value) -> str:
    if pd.isna(value):
        return ""

    value = str(value)
    value = value.replace("\n", " ")
    value = value.replace("\r", " ")
    value = re.sub(r"\s+", " ", value)

    return value.strip()


def safe_get(row, column_name, default=""):
    if column_name in row:
        return row[column_name]
    return default


def extract_and_concat_text(json_string: str) -> str:
    """
    Zelfde idee als in test_agent.py.

    De agent geeft soms content terug als:
    {"content":[{"type":"text","text":"antwoord..."}]}

    Of als:
    [{"type":"text","text":"antwoord..."}]

    Deze functie probeert daar alleen de echte tekst uit te halen.
    """
    if not json_string:
        return ""

    try:
        json_string = str(json_string)

        pattern = r'"text"\s*:\s*"((?:\\.|[^"\\])*)"'
        matches = re.findall(pattern, json_string)

        if matches:
            cleaned = [
                bytes(m, "utf-8").decode("unicode_escape")
                for m in matches
            ]
            return " ".join(cleaned).strip()

        return json_string.strip()

    except Exception:
        return str(json_string)


def simple_keyword_score(expected_answer: str, actual_answer: str) -> float:
    """
    Simpele pragmatische score.
    Geen wetenschappelijke metric, alleen handig om snel slechte antwoorden te vinden.
    """
    expected_answer = normalize_text(expected_answer).lower()
    actual_answer = normalize_text(actual_answer).lower()

    words = [
        word.strip(".,;:!?()[]{}\"'")
        for word in expected_answer.split()
    ]

    words = [
        word for word in words
        if len(word) > 3
    ]

    if not words:
        return 0.0

    hits = [
        word for word in words
        if word in actual_answer
    ]

    return round(len(hits) / len(words), 3)


def get_answer_from_result(result) -> str:
    """
    Haalt het antwoord uit exact dezelfde plek als test_agent.py:
    result["messages"][-1].content
    """
    try:
        content = result["messages"][-1].content
        return extract_and_concat_text(content)
    except Exception:
        return extract_and_concat_text(str(result))


def load_questions() -> pd.DataFrame:
    print("Loading evaluation questions")

    if not os.path.exists(INPUT_FILE):
        raise FileNotFoundError(f"Input file not found: {INPUT_FILE}")

    questions = pd.read_csv(INPUT_FILE)

    if "question" not in questions.columns:
        raise ValueError("De CSV moet minimaal een kolom 'question' hebben.")

    if "id" not in questions.columns:
        questions.insert(0, "id", range(1, len(questions) + 1))

    if "expected_answer" not in questions.columns:
        questions["expected_answer"] = ""

    for col in questions.columns:
        questions[col] = questions[col].apply(normalize_text)

    if LIMIT_QUESTIONS is not None:
        questions = questions.head(LIMIT_QUESTIONS)

    print(f"Loaded {len(questions)} evaluation questions")

    return questions


def print_config_check():
    """
    Hiermee kun je controleren of jouw script dezelfde CONFIG gebruikt
    als de werkende test_agent.py van je collega.
    """
    if not DEBUG:
        return

    print("==================================================")
    print("CONFIG CHECK")
    print("==================================================")

    print("Current working directory:")
    print(os.getcwd())

    print("CONFIG env:")
    print(os.environ.get("CONFIG"))

    try:
        config = load_config(os.environ["CONFIG"])

        print("Config loaded")

        if "vectordatabase" in config:
            print("Vectordatabase config:")
            pprint(config["vectordatabase"])
        else:
            print("Geen 'vectordatabase' key gevonden in config")

        if "chatmodel" in config:
            print("Chatmodel config:")
            pprint(config["chatmodel"])

        if "embeddingmodel" in config:
            print("Embeddingmodel config:")
            pprint(config["embeddingmodel"])

    except Exception as e:
        print("Config kon niet worden geladen/geprint:")
        print(str(e))

    print("==================================================")


def extract_debug_from_result(result) -> str:
    """
    Bewaart een verkorte debug-versie van de result.
    Handig om te zien of tools/retrieval/citations terugkomen.
    """
    try:
        return json.dumps(
            result,
            ensure_ascii=False,
            default=str
        )
    except Exception:
        return str(result)


# ========================================================
# EVALUATION
# ========================================================

async def run_evaluation(questions: pd.DataFrame) -> pd.DataFrame:
    print("Starting RAG evaluation")

    print_config_check()

    print("Initializing chat model")
    chat_model = get_chat_model()

    print("Building RAG agent")

    # Dit is de belangrijke call uit test_agent.py
    agent = build_rag_agent(
        chat_model,
        use_combined_model=USE_COMBINED_MODEL,
        enable_phoenix=ENABLE_PHOENIX
    )

    print("RAG agent ready")

    results = []

    # Zelfde werkwijze als test_agent.py
    history = []

    for index, row in questions.iterrows():
        question_id = safe_get(row, "id", index + 1)
        question = safe_get(row, "question", "")
        expected_answer = safe_get(row, "expected_answer", "")

        topic = safe_get(row, "topic", "")
        expected_source = safe_get(row, "expected_source", "")
        fonds = safe_get(row, "fonds", "")
        kennisbank = safe_get(row, "kennisbank", "")
        k = safe_get(row, "k", "")

        print(f"Running question {question_id}: {question[:120]}")

        start_time = time.time()

        actual_answer = ""
        error = ""
        raw_result = ""

        try:
            if USE_CONVERSATION_HISTORY:
                # Exact zoals test_agent.py:
                # vraag toevoegen aan history
                history.append(HumanMessage(content=question))

                result = await agent.ainvoke({
                    "messages": history
                })

                actual_answer = normalize_text(
                    get_answer_from_result(result)
                )

                # antwoord toevoegen aan history
                history.append(AIMessage(content=actual_answer))

            else:
                # Alternatief: elke vraag volledig los
                local_history = [
                    HumanMessage(content=question)
                ]

                result = await agent.ainvoke({
                    "messages": local_history
                })

                actual_answer = normalize_text(
                    get_answer_from_result(result)
                )

            raw_result = extract_debug_from_result(result)

            if DEBUG:
                print("Actual answer:")
                print(actual_answer[:500])
                print("--------------------------------------------------")

        except Exception as e:
            error = str(e)
            print(f"Error bij question {question_id}: {error}")

        latency_seconds = round(time.time() - start_time, 3)

        keyword_score = simple_keyword_score(
            expected_answer=expected_answer,
            actual_answer=actual_answer
        )

        results.append({
            "id": question_id,
            "topic": topic,
            "question": question,
            "expected_answer": expected_answer,
            "actual_answer": actual_answer,
            "expected_source": expected_source,
            "fonds": fonds,
            "kennisbank": kennisbank,
            "k": k,
            "keyword_score": keyword_score,
            "latency_seconds": latency_seconds,
            "error": error,
            "raw_result": raw_result
        })

        # Tussentijds opslaan.
        # Als hij halverwege faalt, ben je niet alles kwijt.
        pd.DataFrame(results).to_csv(OUTPUT_FILE, index=False)

    return pd.DataFrame(results)


def main():
    ensure_output_dir()

    questions = load_questions()

    results = asyncio.run(
        run_evaluation(questions)
    )

    results.to_csv(OUTPUT_FILE, index=False)

    print("Finished RAG evaluation")
    print(f"Saved results to: {OUTPUT_FILE}")


if __name__ == "__main__":
    main()
